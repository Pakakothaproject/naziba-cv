{
  "name": "careercraft",
  "version": "2.0.0",
  "description": "CareerCraft AI - CV & Cover Letter Optimizer",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/public','dist/public',{recursive:true})\"",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "inject-key": "node inject-api-key.cjs",
    "deploy:cloudflare": "npm run inject-key && npx wrangler pages deploy docs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
